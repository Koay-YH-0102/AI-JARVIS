// ============================================================
buildCoreTicks('core-svg');
buildCoreTicks('core-svg-focus');
loadConfigIntoUI();
pollSystemInfo();
refreshNotifications();
setInterval(pollSystemInfo, 8000);
setInterval(refreshNotifications, 5000);

if (localStorage.getItem('jarvis_clap_toggle') === '1') {
  startClapDetection();
}
