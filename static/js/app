attachBtn.addEventListener('click', () => fileInput.click());
fileInput.addEventListener('change', async () => {
  if (!fileInput.files.length) return;
  await uploadFiles(fileInput.files, { attach: true });
  fileInput.value = '';
});

async function uploadFiles(fileList, { attach = true } = {}) {
  const formData = new FormData();
  for (const f of fileList) formData.append('files', f);
  try {
    const res = await fetch('/api/upload', { method: 'POST', body: formData });
    const data = await res.json();
    if (data.ok) {
      if (attach) {
        data.files.forEach(f => pendingAttachments.push(f));
        renderAttachmentChips();
      }
      logEvent(`Uploaded ${data.files.length} file(s)`, 'ok');
      return data.files;
    }
    addMessage('error', data.error || 'Upload failed.');
  } catch (e) {
    addMessage('error', "Couldn't reach the local server to upload files.");
  }
  return [];
}

function renderAttachmentChips() {
  composerAttachments.innerHTML = '';
  pendingAttachments.forEach(f => {
    const chip = document.createElement('div');
    chip.className = 'attachment-chip';
    const label = document.createElement('span');
    label.textContent = `${fileIcon(f.category)} ${f.name}`;
    const removeBtn = document.createElement('button');
    removeBtn.className = 'chip-remove';
    removeBtn.textContent = '×';
    removeBtn.title = 'Remove';
    removeBtn.addEventListener('click', () => {
      pendingAttachments = pendingAttachments.filter(x => x.id !== f.id);
      renderAttachmentChips();
    });
    chip.appendChild(label);
    chip.appendChild(removeBtn);
    composerAttachments.appendChild(chip);
  });
}

// ============================================================
// Chat send / receive
// ============================================================
async function sendMessage() {
  const text = chatInput.value.trim();
  if (!text && pendingAttachments.length === 0) return;

  const attachmentIds = pendingAttachments.map(f => f.id);
  const attachmentNames = pendingAttachments.map(f => f.name);
  chatInput.value = '';
  autoResizeInput();
  pendingAttachments = [];
  renderAttachmentChips();

  let displayText = text;
  if (attachmentNames.length) {
    displayText += (displayText ? '\n' : '') + `📎 ${attachmentNames.join(', ')}`;
  }
  addMessage('user', displayText);
  setThinking(true);

  try {
    const res = await fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ conversation_id: conversationId, message: text, attachment_ids: attachmentIds }),
    });
    const data = await res.json();
    handleAgentResponse(data);
  } catch (e) {
    setThinking(false);
    addMessage('error', 'Could not reach the local server. Is app.py still running?');
  }
}
sendBtn.addEventListener('click', sendMessage);

function handleAgentResponse(data) {
  if (data.conversation_id) {
    conversationId = data.conversation_id;
    localStorage.setItem('conv_id', conversationId);
  }

  if (data.type === 'final') {
    setThinking(false);
    const message = data.message || '(no response)';
    addMessage('assistant', message);
    speak(message);
  } else if (data.type === 'error') {
    setThinking(false);
    addMessage('error', data.message);
  } else if (data.type === 'confirm') {
    setThinking(false);
    if (data.assistant_note) {
      addMessage('assistant', data.assistant_note);
      speak(data.assistant_note);
    }
    addActionNote(`🔔 Needs approval — "${humanizeToolName(data.name)}". Switched to Notifications.`);
    refreshNotifications();
    switchTab('notifications');
  }
}

function describeAction(name, args) {
  const map = {
    close_application: `Force-close "${args.app_name}". Unsaved work in it may be lost.`,
    shutdown_computer: `Shut down this computer in ${args.delay_seconds ?? 30} seconds.`,
    restart_computer: `Restart this computer in ${args.delay_seconds ?? 30} seconds.`,
    sleep_computer: `Put this computer to sleep right now.`,
    cancel_shutdown: `Cancel a pending shutdown or restart.`,
    delete_file: `Permanently delete the file at "${args.path}".`,
    empty_recycle_bin: `Permanently empty the Recycle Bin.`,
    run_shell_command: `Run this PowerShell command on your machine:`,
    uninstall_hint: `Open Apps & Features so you can uninstall "${args.app_name}" yourself.`,
  };
  return map[name] || 'This action changes something on your system.';
}

// ============================================================
// Notifications tab
// ============================================================
function renderNotifications(items) {
  const pendingCount = items.filter(n => n.status === 'pending').length;
  tabNotifBadge.textContent = pendingCount > 0 ? String(pendingCount) : '';

  if (!items.length) {
    notifList.innerHTML = '<p class="hint">No notifications yet.</p>';
    return;
  }

  notifList.innerHTML = '';
  items.forEach(n => {
    const card = document.createElement('div');
    card.className = `notif-card ${n.status}`;

    const head = document.createElement('div');
    head.className = 'notif-head';
    head.innerHTML = `<span>${humanizeToolName(n.name)}</span><span class="notif-status ${n.status}">${n.status}</span>`;
    card.appendChild(head);

    const desc = document.createElement('p');
    desc.textContent = describeAction(n.name, n.args);
    card.appendChild(desc);

    if (n.args && Object.keys(n.args).length) {
      const pre = document.createElement('pre');
      pre.textContent = JSON.stringify(n.args, null, 2);
      card.appendChild(pre);
    }

    if (n.status === 'pending') {
      const actions = document.createElement('div');
      actions.className = 'notif-actions';
      const denyBtn = document.createElement('button');
      denyBtn.className = 'btn ghost';
      denyBtn.textContent = 'Deny';
      denyBtn.addEventListener('click', () => resolveNotification(n, false));
      const approveBtn = document.createElement('button');
      approveBtn.className = 'btn danger';
      approveBtn.textContent = 'Approve';
      approveBtn.addEventListener('click', () => resolveNotification(n, true));
      actions.appendChild(denyBtn);
      actions.appendChild(approveBtn);
      card.appendChild(actions);
    } else {
      const when = document.createElement('p');
      when.className = 'hint';
      when.textContent = timeAgo(n.resolved_at || n.created_at);
      card.appendChild(when);
    }

    notifList.appendChild(card);
  });
}

async function refreshNotifications() {
  try {
    const res = await fetch('/api/notifications');
    const data = await res.json();
    renderNotifications(data.notifications || []);
  } catch (e) { /* server may be restarting — try again on next poll */ }
}

async function resolveNotification(notif, approved) {
  logEvent(humanizeToolName(notif.name), approved ? 'ok' : 'fail');
  const isCurrentConversation = notif.conversation_id === conversationId;
  if (isCurrentConversation) setThinking(true);

  try {
    const res = await fetch('/api/confirm', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ conversation_id: notif.conversation_id, approved }),
    });
    const data = await res.json();
    if (isCurrentConversation) {
      addActionNote(`${approved ? '✔ approved' : '✘ denied'} — ${humanizeToolName(notif.name)}`);
      handleAgentResponse(data);
    }
  } catch (e) {
    if (isCurrentConversation) {
      setThinking(false);
      addMessage('error', 'Lost connection while confirming that action.');
    }
  }
  refreshNotifications();
}

// ============================================================
// History tab
// ============================================================
async function refreshChats() {
  try {
    const res = await fetch('/api/chats');
    const data = await res.json();
    const items = data.chats || [];
    if (!items.length) {
      chatsList.innerHTML = '<p class="hint">No saved chats yet.</p>';
      return;
    }
    chatsList.innerHTML = '';
    items.forEach(c => {
      const card = document.createElement('div');
      card.className = 'chat-card';
      card.innerHTML = `<span class="chat-title">${c.title || '(untitled)'}</span><span class="chat-time">${timeAgo(c.updated_at)}</span>`;
      card.addEventListener('click', () => loadChat(c.id));
      chatsList.appendChild(card);
    });
  } catch (e) {
    chatsList.innerHTML = '<p class="hint">Could not reach the local server.</p>';
  }
}

async function loadChat(id) {
  try {
    const res = await fetch(`/api/chats/${id}`);
    const data = await res.json();
    if (!data.ok) return;

    conversationId = id;
    localStorage.setItem('conv_id', conversationId);

    chatScroll.innerHTML = '';
    (data.chat.messages || []).forEach(m => {
      if (m.role === 'user') addMessage('user', extractTextFromContent(m.content));
      else if (m.role === 'assistant' && m.content) addMessage('assistant', extractTextFromContent(m.content));
      // tool-call/tool-result messages are skipped in the replay view — the
      // activity log and notifications history cover that level of detail.
    });
    switchTab('chat');
  } catch (e) {
    addMessage('error', "Couldn't load that chat.");
  }
}

newChatBtn.addEventListener('click', () => {
  conversationId = null;
  localStorage.removeItem('conv_id');
  chatScroll.innerHTML = '';
  addActionNote('New chat started.');
});

// ============================================================
// Tasks tab
// ============================================================
async function refreshTasks() {
  try {
    const res = await fetch('/api/tasks');
    const data = await res.json();
    renderTasks(data.tasks || []);
  } catch (e) {
    taskList.innerHTML = '<p class="hint">Could not reach the local server.</p>';
  }
}

function renderTasks(tasks) {
  if (!tasks.length) {
    taskList.innerHTML = '<p class="hint">No tasks yet.</p>';
    return;
  }
  taskList.innerHTML = '';
  tasks.forEach(t => {
    const card = document.createElement('div');
    card.className = `task-card ${t.done ? 'done' : ''}`;

    const checkbox = document.createElement('input');
    checkbox.type = 'checkbox';
    checkbox.checked = t.done;
    checkbox.addEventListener('change', () => toggleTask(t.id, checkbox.checked));

    const textEl = document.createElement('span');
    textEl.className = 'task-text';
    textEl.textContent = t.text;

    const actions = document.createElement('div');
    actions.className = 'task-actions';

    const runBtn = document.createElement('button');
    runBtn.className = 'btn small';
    runBtn.textContent = 'Run';
    runBtn.addEventListener('click', () => runTask(t.text));

    const delBtn = document.createElement('button');
    delBtn.className = 'btn ghost small';
    delBtn.textContent = 'Delete';
    delBtn.addEventListener('click', () => deleteTask(t.id));

    actions.appendChild(runBtn);
    actions.appendChild(delBtn);
    card.appendChild(checkbox);
    card.appendChild(textEl);
    card.appendChild(actions);
    taskList.appendChild(card);
  });
}

async function addTask() {
  const text = taskInput.value.trim();
  if (!text) return;
  taskInput.value = '';
  try {
    await fetch('/api/tasks', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text }),
    });
    refreshTasks();
  } catch (e) { /* ignore */ }
}
taskAddBtn.addEventListener('click', addTask);
taskInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') addTask(); });

async function toggleTask(id, done) {
  await fetch(`/api/tasks/${id}`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ done }),
  });
  refreshTasks();
}

async function deleteTask(id) {
  await fetch(`/api/tasks/${id}`, { method: 'DELETE' });
  refreshTasks();
}

function runTask(text) {
  switchTab('chat');
  chatInput.value = text;
  autoResizeInput();
  sendMessage();
}

