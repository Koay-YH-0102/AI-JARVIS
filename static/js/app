// ============================================================
// Core visualization (SVG radial-tick "arc reactor" style dial)
// ============================================================
function buildCoreTicks(svgId) {
  const svg = document.getElementById(svgId);
  if (!svg) return;
  const NS = 'http://www.w3.org/2000/svg';
  const g = document.createElementNS(NS, 'g');
  g.setAttribute('class', 'core-ticks');
  const count = 48, cx = 100, cy = 100, innerR = 82, outerRShort = 90, outerRLong = 97;
  for (let i = 0; i < count; i++) {
    const angle = (i / count) * Math.PI * 2 - Math.PI / 2;
    const isLong = i % 4 === 0;
    const outerR = isLong ? outerRLong : outerRShort;
    const line = document.createElementNS(NS, 'line');
    line.setAttribute('x1', (cx + innerR * Math.cos(angle)).toFixed(2));
    line.setAttribute('y1', (cy + innerR * Math.sin(angle)).toFixed(2));
    line.setAttribute('x2', (cx + outerR * Math.cos(angle)).toFixed(2));
    line.setAttribute('y2', (cy + outerR * Math.sin(angle)).toFixed(2));
    line.setAttribute('class', isLong ? 'tick tick-long' : 'tick');
    g.appendChild(line);
  }
  svg.appendChild(g);
}

function updateCoreCaption() {
  const active = coreWraps[0]; // all core-wraps are kept in sync, so one is representative
  let state = 'idle';
  if (active && active.classList.contains('listening')) state = 'listening…';
  else if (active && active.classList.contains('speaking')) state = 'speaking…';
  else if (active && active.classList.contains('thinking')) state = 'thinking…';
  coreCaptions.forEach(el => { el.textContent = state; });
}

function setThinking(on) {
  coreWraps.forEach(el => el.classList.toggle('thinking', on));
  sendBtn.disabled = on;
  updateCoreCaption();
}

