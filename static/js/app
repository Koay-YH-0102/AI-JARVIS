function switchProviderTab(provider) {
  currentProvider = provider;
  providerTabs.forEach(btn => btn.classList.toggle('active', btn.dataset.provider === provider));
  Object.entries(providerPanes).forEach(([key, pane]) => pane.classList.toggle('active', key === provider));
}
providerTabs.forEach(btn => btn.addEventListener('click', () => switchProviderTab(btn.dataset.provider)));

async function loadConfigIntoUI() {
  const res = await fetch('/api/config');
  const cfg = await res.json();

  switchProviderTab(cfg.provider || 'openrouter');

  openrouterModel.value = cfg.openrouter.model || '';
  openrouterKeyHint.textContent = cfg.openrouter.has_key ? `Current key: ${cfg.openrouter.masked_key}` : 'No key saved yet.';

  googleModel.value = cfg.google.model || '';
  googleKeyHint.textContent = cfg.google.has_key ? `Current key: ${cfg.google.masked_key}` : 'No key saved yet.';

  ollamaUrl.value = cfg.ollama.base_url || 'http://localhost:11434';
  ollamaModel.value = cfg.ollama.model || '';

  whisperModelSelect.value = cfg.whisper.model_size || 'base';
  whisperAvailable = cfg.whisper.available;

  const configured =
    (cfg.provider === 'openrouter' && cfg.openrouter.has_key && cfg.openrouter.model) ||
    (cfg.provider === 'google' && cfg.google.has_key && cfg.google.model) ||
    (cfg.provider === 'ollama' && cfg.ollama.model);

  connStatus.innerHTML = configured
    ? `<span class="led on"></span>${cfg.provider}`
    : '<span class="led off"></span>Not configured';
}

settingsBtn.addEventListener('click', async () => {
  settingsOverlay.classList.add('show');
  await loadConfigIntoUI();
  loadVoiceSettingsIntoUI();
});
settingsCancel.addEventListener('click', () => settingsOverlay.classList.remove('show'));

ollamaRefresh.addEventListener('click', async () => {
  ollamaHint.textContent = 'Checking…';
  await fetch('/api/config', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ ollama: { base_url: ollamaUrl.value.trim() } }),
  });
  try {
    const res = await fetch('/api/ollama/models');
    const data = await res.json();
    if (data.ok) {
      ollamaModelList.innerHTML = data.models.map(m => `<option value="${m}">`).join('');
      ollamaHint.textContent = data.models.length
        ? `Found ${data.models.length} model(s) — pick one from the list or type a name.`
        : 'Connected, but no models pulled yet. Run e.g. "ollama pull llama3.1".';
    } else {
      ollamaHint.textContent = data.error;
    }
  } catch (e) {
    ollamaHint.textContent = 'Could not reach the local server to check Ollama.';
  }
});

settingsSave.addEventListener('click', async () => {
  const body = {
    provider: currentProvider,
    openrouter: { model: openrouterModel.value.trim() },
    google: { model: googleModel.value.trim() },
    ollama: { base_url: ollamaUrl.value.trim(), model: ollamaModel.value.trim() },
    whisper: { model_size: whisperModelSelect.value },
  };
  if (openrouterKey.value.trim()) body.openrouter.api_key = openrouterKey.value.trim();
  if (googleKey.value.trim()) body.google.api_key = googleKey.value.trim();

  await fetch('/api/config', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body),
  });
  openrouterKey.value = '';
  googleKey.value = '';
  saveVoiceSettingsFromUI();
  await loadConfigIntoUI();
  settingsOverlay.classList.remove('show');
});

// ============================================================
// System info polling
// ============================================================
async function pollSystemInfo() {
  try {
    const res = await fetch('/api/system-info');
    const data = await res.json();
    if (data.ok) {
      const i = data.info;
      document.getElementById('sys-cpu').textContent = i.cpu_percent != null ? `${i.cpu_percent}%` : '—';
      document.getElementById('sys-mem').textContent = i.memory_percent != null ? `${i.memory_percent}% (${i.memory_used_gb}/${i.memory_total_gb} GB)` : '—';
      document.getElementById('sys-batt').textContent = i.battery_percent != null ? `${i.battery_percent}%${i.battery_plugged ? ' ⚡' : ''}` : 'n/a';
    }
  } catch (e) { /* server may not be Windows / psutil missing — ignore */ }
}

// ============================================================
// Voice: text-to-speech (JARVIS talks -> core pulses outward + caption shows)
// Captions and the core's "speaking" pulse happen regardless of whether
// audio is enabled, so the Core tab is useful even with voice replies off.
// ============================================================
const ttsSupported = 'speechSynthesis' in window;
let voiceRepliesEnabled = localStorage.getItem('jarvis_voice_replies') === '1';
let silentSpeakTimer = null;

function showCaption(text) {
  if (jarvisCaption) jarvisCaption.textContent = text;
}

function setSpeaking(on) {
  coreWraps.forEach(el => el.classList.toggle('speaking', on));
  updateCoreCaption();
}

function estimateSpeakingDuration(text) {
  // Rough reading-speed estimate, used only when audio is off so the Core
  // tab still visibly "talks" in sync with the caption appearing.
  const words = text.trim().split(/\s+/).filter(Boolean).length;
  const ms = (words / 2.5) * 1000; // ~150 words/minute
  return Math.max(1200, Math.min(ms, 12000));
}

function speak(text) {
  if (!text) return;
  showCaption(text);
  clearTimeout(silentSpeakTimer);

  if (voiceRepliesEnabled && ttsSupported) {
    window.speechSynthesis.cancel();
    const utter = new SpeechSynthesisUtterance(text);
    utter.onstart = () => setSpeaking(true);
    const stop = () => setSpeaking(false);
    utter.onend = stop;
    utter.onerror = stop;
    window.speechSynthesis.speak(utter);
  } else {
    setSpeaking(true);
    silentSpeakTimer = setTimeout(() => setSpeaking(false), estimateSpeakingDuration(text));
  }
}

// ============================================================
// Voice: speech-to-text via local Whisper (faster-whisper on the server).
// The mic records audio in the browser (MediaRecorder), sends it to
// /api/transcribe, and Whisper runs entirely on your machine — no cloud
// speech service involved, unlike the browser's built-in Web Speech API.
// ============================================================
const recordingSupported = 'MediaRecorder' in window && !!(navigator.mediaDevices && navigator.mediaDevices.getUserMedia);
let isListening = false;
let mediaRecorder = null;
let recordedChunks = [];
let silenceLoopId = null;

function pickRecorderMimeType() {
  const candidates = ['audio/webm;codecs=opus', 'audio/webm', 'audio/ogg;codecs=opus', 'audio/mp4'];
  for (const c of candidates) {
    if (window.MediaRecorder.isTypeSupported && window.MediaRecorder.isTypeSupported(c)) return c;
  }
  return '';
}

async function startRecording(sharedStream) {
  if (!recordingSupported) {
    voiceHint.textContent = "This browser doesn't support microphone recording (MediaRecorder API missing).";
    return;
  }
  if (isListening) return;

  let stream = sharedStream;
  let ownStream = false;
  if (!stream) {
    try {
      stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      ownStream = true;
    } catch (e) {
      voiceHint.textContent = 'Microphone permission denied.';
      return;
    }
  }

  recordedChunks = [];
  const mimeType = pickRecorderMimeType();
  try {
    mediaRecorder = mimeType ? new MediaRecorder(stream, { mimeType }) : new MediaRecorder(stream);
  } catch (e) {
    voiceHint.textContent = `Could not start recording: ${e.message}`;
    if (ownStream) stream.getTracks().forEach(t => t.stop());
    return;
  }

  mediaRecorder.ondataavailable = (e) => { if (e.data && e.data.size > 0) recordedChunks.push(e.data); };
  mediaRecorder.onstop = async () => {
    const blob = new Blob(recordedChunks, { type: mediaRecorder.mimeType || 'audio/webm' });
    mediaRecorder = null;
    if (ownStream) stream.getTracks().forEach(t => t.stop());
    await transcribeBlob(blob);
  };

  mediaRecorder.start();
  isListening = true;
  micBtn.classList.add('listening');
  coreWraps.forEach(el => el.classList.add('listening'));
  updateCoreCaption();
  voiceHint.textContent = 'Listening… click the mic to stop, or pause and it stops on its own.';

  monitorForSilence(stream);
}

function stopRecording() {
  if (mediaRecorder && mediaRecorder.state !== 'inactive') mediaRecorder.stop();
  isListening = false;
  micBtn.classList.remove('listening');
  coreWraps.forEach(el => el.classList.remove('listening'));
  updateCoreCaption();
  if (silenceLoopId) { cancelAnimationFrame(silenceLoopId); silenceLoopId = null; }
}

function monitorForSilence(stream) {
  // Short-lived analysis just for auto-stopping a recording after a pause —
  // separate from the always-on clap-detection analyser below.
  const ctx = new (window.AudioContext || window.webkitAudioContext)();
  const source = ctx.createMediaStreamSource(stream);
  const localAnalyser = ctx.createAnalyser();
  localAnalyser.fftSize = 1024;
  source.connect(localAnalyser);
  const data = new Uint8Array(localAnalyser.fftSize);

  const SPEECH_THRESHOLD = 12, SILENCE_MS = 1400, MAX_MS = 15000;
  const startedAt = performance.now();
  let heardSpeech = false, quietSince = null;

  function finish() {
    ctx.close();
    stopRecording();
  }

  function loop() {
    if (!mediaRecorder) { ctx.close(); return; } // stopped elsewhere already
    localAnalyser.getByteTimeDomainData(data);
    let peak = 0;
    for (let i = 0; i < data.length; i++) {
      const v = Math.abs(data[i] - 128);
      if (v > peak) peak = v;
    }
    const now = performance.now();
    if (peak > SPEECH_THRESHOLD) {
      heardSpeech = true;
      quietSince = null;
    } else if (heardSpeech) {
      if (quietSince === null) quietSince = now;
      else if (now - quietSince > SILENCE_MS) return finish();
    }
    if (now - startedAt > MAX_MS) return finish();
    silenceLoopId = requestAnimationFrame(loop);
  }
  loop();
}

async function transcribeBlob(blob) {
  if (blob.size < 800) {
    voiceHint.textContent = "Didn't catch anything — try again.";
    return;
  }
  voiceHint.textContent = 'Transcribing… (first run downloads the Whisper model, this can take a minute)';
  coreWraps.forEach(el => el.classList.add('thinking'));
  updateCoreCaption();

  try {
    const formData = new FormData();
    formData.append('audio', blob, 'speech.webm');
    const res = await fetch('/api/transcribe', { method: 'POST', body: formData });
    const data = await res.json();
    coreWraps.forEach(el => el.classList.remove('thinking'));
    updateCoreCaption();

    if (data.ok) {
      const text = (data.text || '').trim();
      if (text) {
        chatInput.value = (chatInput.value ? chatInput.value + ' ' : '') + text;
        autoResizeInput();
        if (![...tabs].find(t => t.classList.contains('active') && t.dataset.tab === 'chat')) switchTab('chat');
        voiceHint.textContent = '';
      } else {
        voiceHint.textContent = "Didn't catch anything — try again.";
      }
    } else {
      voiceHint.textContent = data.error || 'Transcription failed.';
    }
  } catch (e) {
    coreWraps.forEach(el => el.classList.remove('thinking'));
    updateCoreCaption();
    voiceHint.textContent = "Couldn't reach the local server to transcribe.";
  }
}

micBtn.addEventListener('click', () => { isListening ? stopRecording() : startRecording(); });

if (!recordingSupported) {
  micBtn.disabled = true;
  micBtn.title = "This browser doesn't support microphone recording";
}

// ============================================================
// Voice: clap-to-activate (Web Audio API amplitude spike detector)
// Fully local — no audio is sent anywhere for clap detection itself. When
// two claps land in quick succession, it starts the same Whisper recording
// flow as clicking the mic, reusing this same mic stream.
// ============================================================
let clapStream = null, audioCtx = null, analyser = null, clapRafId = null;
let clapTimestamps = [];

async function startClapDetection() {
  if (audioCtx) return;
  try {
    clapStream = await navigator.mediaDevices.getUserMedia({ audio: true });
  } catch (e) {
    voiceHint.textContent = "Couldn't access the microphone for clap detection.";
    clapToggle.checked = false;
    localStorage.setItem('jarvis_clap_toggle', '0');
    return;
  }
  audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  const source = audioCtx.createMediaStreamSource(clapStream);
  analyser = audioCtx.createAnalyser();
  analyser.fftSize = 1024;
  source.connect(analyser);
  const data = new Uint8Array(analyser.fftSize);
  let cooldownUntil = 0;

  function loop() {
    analyser.getByteTimeDomainData(data);
    let peak = 0;
    for (let i = 0; i < data.length; i++) {
      const v = Math.abs(data[i] - 128);
      if (v > peak) peak = v;
    }
    const now = performance.now();
    if (peak > 80 && now > cooldownUntil) {
      cooldownUntil = now + 250;
      clapTimestamps.push(now);
      clapTimestamps = clapTimestamps.filter(t => now - t < 900);
      if (clapTimestamps.length >= 2) {
        clapTimestamps = [];
        if (!isListening) startRecording(clapStream);
      }
    }
    clapRafId = requestAnimationFrame(loop);
  }
  loop();
}

function stopClapDetection() {
  if (clapRafId) cancelAnimationFrame(clapRafId);
  clapRafId = null;
  if (clapStream) clapStream.getTracks().forEach(t => t.stop());
  clapStream = null;
  if (audioCtx) audioCtx.close();
  audioCtx = null;
  analyser = null;
}

let whisperAvailable = true; // updated from /api/config each time Settings opens

function loadVoiceSettingsIntoUI() {
  voiceRepliesToggle.checked = voiceRepliesEnabled;
  clapToggle.checked = localStorage.getItem('jarvis_clap_toggle') === '1';
  const notes = [];
  if (!ttsSupported) notes.push('Speech synthesis (voice replies) is not supported in this browser.');
  if (!recordingSupported) notes.push('Voice input needs a browser with MediaRecorder support (all modern browsers have this).');
  if (!('mediaDevices' in navigator)) notes.push('Clap detection needs microphone access, which this context does not allow (use http://127.0.0.1 or https).');
  if (!whisperAvailable) notes.push("faster-whisper isn't installed on the server — voice input won't work until you run: pip install faster-whisper");
  voiceSupportHint.textContent = notes.join(' ');
}

function saveVoiceSettingsFromUI() {
  voiceRepliesEnabled = voiceRepliesToggle.checked;
  localStorage.setItem('jarvis_voice_replies', voiceRepliesEnabled ? '1' : '0');

  const wantsClap = clapToggle.checked;
  localStorage.setItem('jarvis_clap_toggle', wantsClap ? '1' : '0');
  if (wantsClap) startClapDetection(); else stopClapDetection();
}

// ============================================================
